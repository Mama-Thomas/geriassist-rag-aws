# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Database (AWS RDS)
DB_HOST=your-rds-endpoint.us-west-2.rds.amazonaws.com
DB_PORT=5432
DB_NAME=geriassist
DB_USER=postgres
DB_PASSWORD=your-password

# AWS
AWS_REGION=us-west-2
AWS_S3_BUCKET=geriassist-docs-mamathomas

# App
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini
CHUNK_SIZE=500
TOP_K=5
FAISS_INDEX_PATH=faiss_index

# NCBI API key for PubMed / PMC requests (raises rate limit from 3 req/s to 10 req/s)
NCBI_API_KEY=your_ncbi_key_here

# CORE API key for retrieving open-access research papers
CORE_API_KEY=your_core_key_here
